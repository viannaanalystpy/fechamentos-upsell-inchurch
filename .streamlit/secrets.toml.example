# Copie este arquivo para secrets.toml e preencha os valores.
# No Streamlit Cloud, configure via Settings > Secrets (não precisa subir o arquivo).

[google]
client_id     = "SEU_CLIENT_ID.apps.googleusercontent.com"
client_secret = "SEU_CLIENT_SECRET"
redirect_uri  = "https://SEU_APP.streamlit.app"

[gcp_service_account]
type                        = "service_account"
project_id                  = "business-intelligence-467516"
private_key_id              = "KEY_ID"
private_key                 = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
client_email                = "SERVICEACCOUNT@business-intelligence-467516.iam.gserviceaccount.com"
client_id                   = "CLIENT_ID_NUMERICO"
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "https://www.googleapis.com/robot/v1/metadata/x509/..."
